<div class="container mt-5">
  <h2>Editar categoria</h2>

  <%= form_with model: @kind, local: true, class: "card p-4 shadow" do |form| %>
    <% if @kind.errors.any? %>
      <div class="alert alert-danger">
        <%= @kind.errors.full_messages.join(", ") %>
      </div>
    <% end %>

    <div class="mb-3">
      <%= form.label :name, class: "form-label" %>
      <%= form.text_field :name, class: "form-control" %>
    </div>

    <%= form.submit "Guardar cambios", class: "btn btn-primary" %>
    <%= link_to "Cancelar", admins_path, class: "btn btn-secondary ms-2" %>
  <% end %>
</div>
