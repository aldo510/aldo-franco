<nav class="navbar navbar-expand-lg navbar-dark fixed-top position-absolute" id="transparent-navbar">
  <%= link_to root_path, class: 'navbar-brand' do %>
    <%= image_tag 'icons/logoblanco.svg', id: 'logo-navbar' %>
  <% end %>
  <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
    <span class="navbar-toggler-icon"></span>
  </button>
  <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
    <ul class="navbar-nav">
      <li class="nav-item">
        <%= link_to "home", root_path, class: "nav-link white-navbar", data:{target: "banner"} %>      
      </li>
      <li class="nav-item">
        <%= link_to "about", root_path + "#abount-us", class: "nav-link white-navbar", data:{target: "banner"} %>    
      </li>
      <li class="nav-item">
        <%= link_to "work", root_path + "#work", class: "nav-link white-navbar work-content", data:{target: "work"} %>  
      </li>
      <li class="nav-item">
        <%#= link_to "Jobs", root_path + "#contact", class: "nav-link white-navbar", data:{target: "banner"} %> 
        <a class="nav-link white-navbar" data-target="contact">Jobs</a>
      </li>
      <li class="nav-item">
        <%= link_to "Team", about_path, class: "nav-link white-navbar" %>
      </li>
      <li class="nav-item">
        <%#= link_to "Contact", root_path + "#contact", class: "nav-link white-navbar", data:{target: "banner"} %> 
        <a class="nav-link white-navbar" data-target="contact">Contact</a>
      </li>
    </ul>
  </div>

  <ul id="nav-social" class="d-none d-lg-flex">
    <li>
      <a href="">
        <%= image_tag 'icons/face-white.svg' %>
      </a>
    </li>
    <li>
      <a href="">
        <%= image_tag 'icons/instagram-white.svg' %>
      </a>
    </li>
    <li>
      <a href="">
        <%= image_tag 'icons/linkedin-white.svg' %>
      </a>
    </li>
  </ul>
<div class="col-12 mx-auto text-white" id="work-div" style="display: none;">
  <div class="row">
    <div class="col-8 mx-auto">
      <ul class="work-ul">
        <% @build_hash.keys.each do |key| %>
          <%= link_to key.capitalize, buildings_path(target: "#{key}"), class: 'text-uppercase col sections text-white', data: { target: "#{key[0..2]}-div" } %>
        <% end %>
      </ul>
    </div>

    <% @build_hash.each do |key, buildings| %>
      <%= content_tag :div, class: "col-6 mx-auto #{key[0..2]}-div sections-content", style: 'display: none;' do  %>
        <div class="row">
          <% buildings.each do | b | %>
            <div class="col-3">
              <%= link_to b.name.capitalize, building_path(b), class: "text-white menu-li text-capitalize" %>
            </div>
          <% end %>
        </div>
      <% end %>
    <% end %>
    
  </div>
</div>
</nav>