<nav class="navbar navbar-expand-lg navbar-light bg-light" id="white-navbar">
  <!-- <a class="navbar-brand" href="#">Navbar</a> -->
  <%= link_to root_path, class: 'navbar-brand' do %>
  <%= image_tag 'logo-black.svg', id: 'logo-navbar' %>
  <% end %>
  <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
    <span class="navbar-toggler-icon"></span>
  </button>
  <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
    <ul class="navbar-nav">
      <li class="nav-item">
        <%= link_to "home", root_path, class: "nav-link got-thi white-navbar", data:{target: "banner"} %>
      </li>
      <li class="nav-item">
        <% if controller.action_name == "about" %>
          <%= link_to "About", root_path + "#abount-us", class: "nav-link got-thi white-navbar work-content-2" %>
        <% else %>
          <p class="nav-link got-thi white-navbar work-content-2" data-target="work">About</p>
        <% end %>
      </li>
      <li class="nav-item">
        <% if controller.action_name == "about" %>
          <%= link_to "Work", root_path + "#work", class: "nav-link got-thi white-navbar work-content-2" %>
        <% else %>
          <p class="nav-link got-thi white-navbar work-content-2" data-target="work">Work</p>
        <% end %>
      </li>
      <li class="nav-item">
        <% if controller.action_name == "about" %>
          <%= link_to "Jobs", root_path + "#contact", class: "nav-link got-thi white-navbar work-content-2" %>
        <% else %>
          <p class="nav-link got-thi white-navbar work-content-2" data-target="work">Jobs</p>
        <% end %>
      </li>
      <li class="nav-item">
        <%= link_to "Team", about_path, class: "nav-link got-thi white-navbar" %>
      </li>
      <li class="nav-item">
        <a class="nav-link got-thi white-navbar" data-target="contact">Contact</a>
      </li>
    </ul>
  </div>

  <ul id="nav-social" class="d-none d-lg-flex">
    <li>
      <a href="">
        <%= image_tag 'icons/face.svg' %>
      </a>
    </li>
    <li>
      <a href="">
        <%= image_tag 'icons/instagram.svg' %>
      </a>
    </li>
    <li>
      <a href="">
        <%= image_tag 'icons/linkedin.svg' %>
      </a>
    </li>
  </ul>
</nav>
<div class="col-12 mx-auto text-white" id="work-div-2" style="display: none;">
  <div class="row">
    <div class="col-8 mx-auto">
      <ul class="work-ul-2">
        <% @build_hash.keys.each do |key| %>
          <%= link_to key.capitalize, buildings_path(target: "#{key}"), class: 'text-uppercase col sections-2 text-black', data: { target: "#{key[0..2]}-div" } %>
        <% end %>
      </ul>
    </div>

    <% @build_hash.each do |key, buildings| %>
      <%= content_tag :div, class: "col-6 mx-auto #{key[0..2]}-div sections-content-2", style: 'display: none;' do  %>
       <div class="row">
          <% buildings.each do | b | %>
            <div class="col-3">
              <%= link_to b.name.capitalize, building_path(b), class: "text-black menu-li text-capitalize" %>
            </div>
          <% end %>
        </div>
      <% end %>
    <% end %>
    
  </div>
</div>
