<div class="container mt-5">
  <h2 class="mb-4">Administradores</h2>

  <%= link_to "Agregar nuevo admin", new_admin_path, class: "btn btn-success mb-3" %>

  <table class="table table-bordered table-striped">
    <thead>
      <tr>
        <th>Email</th>
      </tr>
    </thead>
    <tbody>
      <% @admins.each do |admin| %>
        <tr>
          <td><%= admin.email %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="container mt-5">
    <h2>Panel de Administración</h2>

    <% @kinds.each do |kind| %>
        <div class="card my-4 shadow">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <strong><%= kind.name.capitalize %></strong>
            <%= link_to "Editar", edit_kind_path(kind), class: "btn btn-sm btn-warning" %>
        </div>
        <div class="card-body">
            <% if kind.buildings.any? %>
            <ul class="list-group">
                <% kind.buildings.each do |building| %>
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <%= link_to building.name, building_path(building), class: "text-decoration-none" %>
                    <span class="badge bg-secondary"><%= building.year %></span>
                </li>
                <% end %>
            </ul>
            <% else %>
            <p>No hay desarrollos en esta categoría.</p>
            <% end %>
        </div>
        </div>
    <% end %>
    </div>

  <%= link_to "Cerrar sesión", logout_path, method: :delete, class: "btn btn-outline-danger mt-3" %>
</div>