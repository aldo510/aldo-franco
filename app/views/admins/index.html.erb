<div class="container my-5">
  <% if notice.present? %>
    <div class="alert alert-success"><%= notice %></div>
  <% end %>
  <% if alert.present? %>
    <div class="alert alert-warning"><%= alert %></div>
  <% end %>

  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h3 mb-1">Panel de administracion</h1>
      <p class="text-muted mb-0"><%= current_admin.email %></p>
    </div>
    <%= link_to "Cerrar sesion", logout_path, method: :delete, class: "btn btn-outline-danger" %>
  </div>

  <div class="row g-3">
    <div class="col-md-4">
      <%= link_to buildings_path, class: "btn btn-outline-dark w-100 p-4 text-start h-100 d-block text-wrap" do %>
        <strong class="d-block h5 mb-2">Desarrollos</strong>
        <span class="text-muted d-block small lh-base">Crear, editar, subir imagenes a S3 y eliminar proyectos.</span>
      <% end %>
    </div>

    <div class="col-md-4">
      <%= link_to kinds_path, class: "btn btn-outline-dark w-100 p-4 text-start h-100 d-block text-wrap" do %>
        <strong class="d-block h5 mb-2">Categorias</strong>
        <span class="text-muted d-block small lh-base">Administrar categorias y revisar sus desarrollos.</span>
      <% end %>
    </div>

    <div class="col-md-4">
      <%= link_to collaborators_path, class: "btn btn-outline-dark w-100 p-4 text-start h-100 d-block text-wrap" do %>
        <strong class="d-block h5 mb-2">Colaboradores</strong>
        <span class="text-muted d-block small lh-base">Editar los colaboradores que aparecen en /about.</span>
      <% end %>
    </div>
  </div>
</div>
