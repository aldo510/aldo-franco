<% content_for :head do %>
<meta name="turbolinks-cache-control" content="no-cache">
<% end %>

<section id="banner">
  <%= render partial: 'layouts/navbar' %>
  <div class="banner-slider" id="home-slider">
    <div class="item-container">
      <%= image_tag 'static_pages/home/1RawRepublic.jpg', class: 'w-100 img-fluid img-banner'  %>
      <%= link_to "Raw Republic", building_path(id: 16), class: "item-title" %>
      <div class="item-title-2">
      </div>
    </div>
    <div class="item-container">
      <%= image_tag 'http://d3tlw7q61ww5gp.cloudfront.net/projects/buildings/METALITEC/OFICINAS.SANISIDRO.V12.PL.170620_Camera001-copia-(2).jpg', class: 'w-100 img-fluid img-banner'  %>
      <%= link_to "Metalitec", building_path(id: 23), class: "item-title" %>
      <div class="item-title-2">
      </div>
    </div>
    <div class="item-container">
      <%= image_tag 'static_pages/home/3BosquedeCanelos.jpg', class: 'w-100 img-fluid img-banner'  %>
      <%= link_to "Bosque de Canelos", building_path(id: 4), class: "item-title" %>
      <div class="item-title-2">
      </div>
    </div>
    <div class="item-container">
      <%= image_tag 'http://d3tlw7q61ww5gp.cloudfront.net/projects/buildings/PUMA/PUMASTORE.V2.PL.010122_PhysCamera003.jpg', class: 'w-100 img-fluid img-banner' %>
      <%= link_to "Puma México ", building_path(id: 15), class: "item-title" %>
      <div class="item-title-2">
      </div>
    </div>
    <div class="item-container">
      <%= image_tag 'static_pages/home/6CARSOAP.jpg', class: 'w-100 img-fluid img-banner'  %>
      <%= link_to "Carso AP", building_path(id: 3), class: "item-title" %>
      <div class="item-title-2">
      </div>
    </div>
    <div class="item-container">
      <%= image_tag 'static_pages/home/jacobs.jpg', class: 'w-100 img-fluid'  %>
      <%= link_to "Jacobs México", building_path(id: 27), class: "item-title" %>
      <div class="item-title-2">
      </div>
    </div>
  </div>
  <%= image_tag 'static_pages/home/left_arrow.svg', id: 'left-arrow', class: 'slider-arrows  d-lg-block'  %>
  <%= image_tag 'static_pages/home/right_arrow.svg', id: 'right-arrow', class: 'slider-arrows  d-lg-block'  %>
  <div id="dots-container" class="d-none d-lg-block">
    <ul id="dot-list">
    </ul>
  </div>
  
</section>

<section id="abount-us">
  <div class="container-fluid">
    <div class="row">
      <div class="col pad-top-5 pad-bot-5">
        <h2 class="abount-us-title"><span>we design</span> spaces</h2>
        <h2 class="abount-us-title">creating <span>unique experiences</span></h2>
      </div>
    </div>

    <div class="row align-items-end d-flex">
      <div class="col-10 mx-auto">
        <div class="row pad-bot-5 d-none d-sm-block">
          <div class="col-5" id="logo-puntos">
            <%= image_tag "static_pages/home/logopuntos.svg", class: "img-fluid"  %>
          </div>
        </div>
        <div class="row">
          <div class="col-12 mx-auto col-sm-5">
            <h3 class="text-uppercase text-white text-center text-lg-left" id="about-title">about us</h3>
            <br>
            
            <p class="pad-bot-5 text-justify about-text" id="t1">
              We are a group of architects specialized in designing and building projects with beautiful and functional spaces
              where the good design is implicit always.
              We design sustainable spaces in which we take care of every single detail.
            </p>

            <p class="pad-bot-5 text-justify about-text" id="t2" style="display: none;">
              We believe that architecture is one of the few profesions that directly improve the quality of life of people.
              Our office works always with passion and respect for the client, the nature, the materials and the design. We are
              constantly looking for new materials designing spaces or things that have never been made integrating all the
              arts in our architecture and in its atmosphere.
            </p>

            <p class="pad-bot-5 text-justify about-text" id="t3" style="display: none;">
              Each project is made based on a research process in which we put the maximum attention to each corner,
              each color, each material, each finish, each entry of light, always focusing in design excellence and integrity,
              this is what we are most passionate about .
            </p>

            <div class="row">
              <div class="col-7 col-sm-5 border-top pad-top-5">
                <ul class="lista">
                  <li class="active-item-li" data-text="t1">1</li>
                  <li class="" data-text="t2">2</li>
                  <li class="" data-text="t3">3</li>
                </ul>
              </div>
            </div>
          </div>
          <div class="col-sm-7 col-5 d-none d-sm-block" id="img-about">
            <%= image_tag "static_pages/home/OFFICE.jpg", class: "img-fluid" %>
          </div>
        </div>
      </div>
      <div class="col-6"></div>
    </div>
  </div>
</section>

<section id="work">
  <div class="container-fluid">
    <div class="row">
      <div class="col pad-top-5">
        <h2 id="work-title">work</h2>
      </div>
    </div>

    <div class="row">
      <div class="col mx-auto">
        <div id="vertical-line"></div>
      </div>
    </div>

    <div class="row">
      <div class="col-sm-9 col-10 col-sm-6 mx-auto">
        <p id="work-description">
        </p>
      </div>
    </div>

    <div class="row">
      <div class="col mx-auto">
        <%= link_to 'All projects', buildings_path, id: 'all-projects' %>
      </div>
    </div>

    <div class="row" id="categories-background">
      <div class="col-6 col-sm-4 category cat-1">
        <%= link_to buildings_path(target: 'residential') do %>
        <h5>Residential</h5>
        <% end %>
      </div>
      <div class="col-6 col-sm-4 category cat-2">
        <%= link_to buildings_path(target: 'commercial') do %>
        <h5>Commercial</h5>
        <% end %>
      </div>
      <div class="col-6 col-sm-4 category cat-3">
        <%= link_to buildings_path(target: 'office') do %>
        <h5>Office</h5>
        <% end %>
      </div>
      <!-- <div class="col-6 col-sm-4 category cat-4">
        <%#= link_to buildings_path(target: 'health') do %>
        <h5>Health</h5>
        <%# end %>
      </div> -->
      <div class="col-6 col-sm-4 category cat-5">
        <%= link_to buildings_path(target: 'education') do %>
        <h5>Education</h5>
        <% end %>
      </div>
      <div class="col-6 col-sm-4 category cat-6">
        <%= link_to buildings_path(target: 'cultural') do %>
        <h5>Cultural</h5>
        <% end %>
      </div>
      <div class="col-6 col-sm-4 category cat-7">
        <%= link_to buildings_path(target: 'publics') do %>
        <h5>Public</h5>
        <% end %>
      </div>
      <div class="col-6 col-sm-4 category cat-8">
        <%= link_to buildings_path do %>
        <h5>All</h5>
        <% end %>
      </div>
    </div>
  </div>
</section>

<%= render partial: 'layouts/contact' %>

<% if @first_time %>
<%= render partial: 'intro' %>
<% end %>

<script>
  $( document ).ready(function() {

    var numslider = $(".banner-slider .item-container").length;
    for(var i = 0; i< numslider;i++){
      $('#dot-list').append('<li class="dot" id="dot-'+i+'"></li>');
    }
    $('.banner-slider').slick({
      autoplay: true,
      infinite: true,
      dots: false,
      arrows: false
    });

    $(document).keydown(function(e){
      if (e.keyCode == 39) {
        $('.banner-slider').slick('slickNext');
        return false;
      }else if (e.keyCode == 37) {
        $('.banner-slider').slick('slickPrev');
        return false;
      }
    });
    
    $('#left-arrow').click(function() {
      $('.banner-slider').slick('slickPrev');
    });

    $('#right-arrow').click(function() {
      $('.banner-slider').slick('slickNext');
    });

    var currentSlide = $('.banner-slider').slick('slickCurrentSlide');
    $('.img-banner').click(function () {
      $( '.banner-slider-2' ).slick('slickGoTo', currentSlide );
      $('#banner-clic').show();
      $('.banner-slider-2').fadeIn();
      $('#banner-clic').css('z-indez', '13');
      $('#close-arrow').show();
      $('#left-arrow-2').show();
      $('#right-arrow-2').show();
    });
    $('.banner-slider').on('afterChange', function(event, slick, currentSlide, nextSlide){
      $('.dot').removeClass('active');
      $('#dot-'+currentSlide).addClass('active');
    });
    $('#dot-'+currentSlide).addClass('active');

    $('.banner-slider').on('afterChange', function(event, slick, currentSlide, nextSlide){
      $('.dot').removeClass('active');
      $('#dot-'+currentSlide).addClass('active');
    });

    $('.cat-1').hover(function () {
      var imagePath = "<%= asset_url   "static_pages/home/RESIDENCIAL.jpg" %>";
      $('#categories-background').css('background-image', "url(" + imagePath + ")");
    });
    $('.cat-2').hover(function () {
      var imagePath = "<%= asset_url   "static_pages/home/work_background.jpg" %>";
      $('#categories-background').css('background-image', "url(" + imagePath + ")");
    });
    $('.cat-3').hover(function () {
      var imagePath = "<%= asset_url   "static_pages/home/OFFICE.jpg" %>";
      $('#categories-background').css('background-image', "url(" + imagePath + ")");
    });
    $('.cat-4').hover(function () {
      var imagePath = "<%= asset_url   "static_pages/home/work_background.jpg" %>";
      $('#categories-background').css('background-image', "url(" + imagePath + ")");
    });
    $('.cat-5').hover(function () {
      var imagePath = "<%= asset_url   "static_pages/home/EDUCATION.jpg" %>";
      $('#categories-background').css('background-image', "url(" + imagePath + ")");
    });
    $('.cat-6').hover(function () {
      var imagePath = "<%= asset_url   "static_pages/home/CULTURAL.jpg" %>";
      $('#categories-background').css('background-image', "url(" + imagePath + ")");
    });
    $('.cat-7').hover(function () {
     var imagePath = "<%= asset_url   "static_pages/home/PUBLIC.jpg" %>";
     $('#categories-background').css('background-image', "url(" + imagePath + ")");
   });
    $('.cat-8').hover(function () {
      var imagePath = "<%= asset_url   "static_pages/home/ALL.jpg" %>";
      $('#categories-background').css('background-image', "url(" + imagePath + ")");
    });
    $('.cat-9').hover(function () {
      var imagePath = "<%= asset_url   "static_pages/home/work_background.jpg" %>";
      $('#categories-background').css('background-image', "url(" + imagePath + ")");
    });

  });

</script>

